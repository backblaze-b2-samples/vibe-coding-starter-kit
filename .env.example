# Backblaze B2 (required)
B2_ENDPOINT=your_b2_endpoint
B2_KEY_ID=your_key_id
B2_APPLICATION_KEY=your_application_key
B2_BUCKET_NAME=your-bucket-name

# Example of what filled-in values look like (fake — for visual reference only):
# B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
# B2_KEY_ID=00abcdef1234567000000001
# B2_APPLICATION_KEY=K001AbCdEfGhIjKlMnOpQrStUvWxYz0=
# B2_BUCKET_NAME=my-app-uploads

# Frontend → API base URL. Defaults to http://localhost:8000 for local dev;
# set this to the deployed API origin in production (Next.js inlines it at
# build time, so it must be present when `pnpm build` runs).
# NEXT_PUBLIC_API_URL=https://your-api.example.com
